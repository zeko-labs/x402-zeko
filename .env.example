# Copy to `.env` for local development. Do not commit real keys.

# Buyer / payer.
X402_EVM_PRIVATE_KEY=replace_with_buyer_private_key
X402_EVM_BUYER_ADDRESS=replace_with_buyer_address

# Relayer / gas payer.
X402_EVM_RELAYER_PRIVATE_KEY=replace_with_relayer_private_key
X402_EVM_RELAYER_ADDRESS=replace_with_relayer_address

# Dedicated receiving wallet for production-style payTo routing.
X402_EVM_PAY_TO_ADDRESS=replace_with_payto_address
X402_EVM_PAY_TO=replace_with_payto_address
X402_BASE_PAY_TO=replace_with_base_payto_address
X402_ETHEREUM_PAY_TO=replace_with_ethereum_payto_address

# Base defaults.
X402_EVM_NETWORK=base
X402_BASE_RPC_URL=https://mainnet.base.org
# Optional failover list for hosted/self-hosted facilitator mode.
X402_BASE_RPC_URLS=https://mainnet.base.org,https://base-rpc.publicnode.com
X402_EVM_AMOUNT=0.01

# Base Sepolia escrow deployment defaults.
X402_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
X402_BASE_SEPOLIA_DEPLOYER_PRIVATE_KEY=replace_with_base_sepolia_deployer_private_key
X402_BASE_SEPOLIA_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
X402_BASE_SEPOLIA_ESCROW_ADMIN=replace_with_escrow_admin_address
X402_BASE_SEPOLIA_ESCROW_RELEASER=replace_with_escrow_releaser_address
X402_BASE_SEPOLIA_TOKEN_ADDRESS=optional_existing_test_token_address
X402_BASE_SEPOLIA_ESCROW_ADDRESS=optional_existing_test_escrow_address
X402_BASE_SEPOLIA_USDC_AMOUNT=0.01

# Ethereum Sepolia escrow deployment defaults.
X402_ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
X402_ETHEREUM_SEPOLIA_DEPLOYER_PRIVATE_KEY=replace_with_ethereum_sepolia_deployer_private_key
X402_ETHEREUM_SEPOLIA_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
X402_ETHEREUM_SEPOLIA_ESCROW_ADMIN=replace_with_ethereum_sepolia_escrow_admin_address
X402_ETHEREUM_SEPOLIA_ESCROW_RELEASER=replace_with_ethereum_sepolia_escrow_releaser_address
X402_ETHEREUM_SEPOLIA_TOKEN_ADDRESS=optional_existing_test_token_address
X402_ETHEREUM_SEPOLIA_ESCROW_ADDRESS=optional_existing_test_escrow_address
X402_ETHEREUM_SEPOLIA_USDC_AMOUNT=0.01

# Optional self-hosted facilitator service.
# For Render or another web host, set HOST to 0.0.0.0 and PORT to the platform port.
X402_EVM_FACILITATOR_HOST=127.0.0.1
X402_EVM_FACILITATOR_PORT=7422

# Ethereum rail.
X402_ETHEREUM_RPC_URL=https://ethereum.publicnode.com
X402_ETHEREUM_RPC_URLS=https://ethereum.publicnode.com,https://rpc.ankr.com/eth
X402_ETHEREUM_USDC_AMOUNT=0.01

# Zeko rail.
# Zeko testnet amounts below are denominated in tMINA.
ZEKO_GRAPHQL=https://testnet.zeko.io
ZEKO_ARCHIVE=https://archive.testnet.zeko.io/graphql
X402_ZKAPP_PUBLIC_KEY=replace_with_zeko_settlement_contract
X402_PAYER_PRIVATE_KEY=replace_with_zeko_payer_private_key
